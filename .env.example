# =============================================================================
# AUTH — pick ONE mode.
# =============================================================================
# Mode is inferred when VITE_AUTH_MODE is unset: a VITE_GEMINI_API_KEY present
# => 'direct'; absent => 'ephemeral'. Set it explicitly to be unambiguous.
# VITE_AUTH_MODE=direct
#
# --- direct mode (LOCAL DEV ONLY) --------------------------------------------
# Ships the raw key to the browser. Fine for a local demo, NOT for anything
# semi-public. Get a key from https://aistudio.google.com/apikey
# Note: the VITE_ prefix is what makes Vite expose it to the client bundle.
VITE_GEMINI_API_KEY=your-google-genai-api-key-here
#
# --- ephemeral mode (SEMI-PUBLIC) --------------------------------------------
# Leave VITE_GEMINI_API_KEY UNSET and instead set the SERVER-ONLY key below
# (no VITE_ prefix => never bundled to the browser). The browser fetches a
# short-lived ephemeral token from the endpoint; the real key stays on the
# server. The Vite dev/preview server hosts the endpoint automatically.
# GEMINI_API_KEY=your-google-genai-api-key-here
# VITE_AUTH_MODE=ephemeral
# VITE_AUTH_TOKEN_ENDPOINT=/api/auth-token
# Optional server-side overrides for the minted token:
# LYRIA_MODEL=models/lyria-realtime-exp
# AUTH_TOKEN_USES=1
# AUTH_TOKEN_EXPIRY_MINUTES=30

# Lyria RealTime model id (override if Google changes the model name).
VITE_LYRIA_MODEL=models/lyria-realtime-exp

# Hardcoded prompt used to seed a freshly-opened session (overridable).
VITE_LYRIA_INITIAL_PROMPT=lush ambient soundscape
VITE_LYRIA_INITIAL_PROMPT_WEIGHT=1.0

# Default real-time generation parameters applied on connect.
# bpm and scale stay PINNED for the whole performance (changing them mid-stream
# forces a reset_context() seam). Keep guidance low (~2-3) so weighted-prompt
# blends morph gently rather than abruptly. density/brightness are just starting
# points — steering morphs them live as a secondary control.
VITE_LYRIA_BPM=110
VITE_LYRIA_GUIDANCE=2.5
VITE_LYRIA_DENSITY=0.6
VITE_LYRIA_BRIGHTNESS=0.5
# Musical scale/key (SDK Scale enum name), pinned for the performance.
VITE_LYRIA_SCALE=C_MAJOR_A_MINOR

# Transparent reconnection ahead of the ~10-minute Lyria session cap.
# Open the replacement session this many ms after connect (default 510000 =
# 8.5 min), let it settle this long before handoff (default 7000), and crossfade
# old→new over this window (default 2000). Clamped so the handoff always finishes
# before the cap. Lower RECONNECT_AFTER to a few seconds to watch a reconnect live.
# VITE_RECONNECT_AFTER_MS=510000
# VITE_RECONNECT_SETTLE_MS=7000
# VITE_RECONNECT_CROSSFADE_MS=2000

# Offline fallback engine. If the Lyria WebSocket errors, closes unexpectedly, or
# goes quiet for this many ms while playing, a local Tone.js synth takes over so
# the demo degrades to a working instrument instead of silence (reliability, not
# parity). It steers from the same emoji mapping (tempo/key/density). Lower this
# (e.g. 1500) to make the fallback engage quickly when demoing an outage.
# VITE_FALLBACK_STALL_MS=4000
