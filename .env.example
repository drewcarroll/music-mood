# Google AI / Lyria RealTime API key.
# Get one from https://aistudio.google.com/apikey
# Note: prefixed with VITE_ so Vite exposes it to the client bundle.
VITE_GEMINI_API_KEY=your-google-genai-api-key-here

# Lyria RealTime model id (override if Google changes the model name).
VITE_LYRIA_MODEL=models/lyria-realtime-exp

# Hardcoded prompt used to seed a freshly-opened session (overridable).
VITE_LYRIA_INITIAL_PROMPT=lush ambient soundscape
VITE_LYRIA_INITIAL_PROMPT_WEIGHT=1.0

# Default real-time generation parameters applied on connect.
# bpm and scale stay PINNED for the whole performance (changing them mid-stream
# forces a reset_context() seam). Keep guidance low (~2-3) so weighted-prompt
# blends morph gently rather than abruptly. density/brightness are just starting
# points — steering morphs them live as a secondary control.
VITE_LYRIA_BPM=110
VITE_LYRIA_GUIDANCE=2.5
VITE_LYRIA_DENSITY=0.6
VITE_LYRIA_BRIGHTNESS=0.5
# Musical scale/key (SDK Scale enum name), pinned for the performance.
VITE_LYRIA_SCALE=C_MAJOR_A_MINOR
